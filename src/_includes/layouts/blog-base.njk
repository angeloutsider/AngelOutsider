<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title | default("Blog") }}</title>
  <link rel="stylesheet" href="{{ site.baseUrl }}static/css/navbar.css">
  <link rel="stylesheet" href="{{ site.baseUrl }}static/css/blog-style.css">
  <script defer src="{{ site.baseUrl }}static/js/script.js"></script>
</head>
<body>
  <div class="overlay-text">
    <a href="{{ site.baseUrl }}home" class="nav-item nav-name">
        <img src="{{ site.baseUrl }}static/images/logo.png" alt="Your Name Logo" class="name-logo">
    </a>
    <div class="nav-links">
        <a href="{{ site.baseUrl }}about/" class="nav-item">about</a>
        <a href="{{ site.baseUrl }}blogs/" class="nav-item">read</a>
        <a href="{{ site.baseUrl }}contact/" class="nav-item">contact</a>
    </div>
</div>
  {{ content | safe }}

    <footer>
        subscribe
    </footer>
</body>
</html>