<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>Blog Post Generator</title>
    <link rel="stylesheet" href="{{ site.baseUrl }}static/css/tool-style.css">
</head>
<body>
    <div class="container">
        <!-- Sidebar -->
        <div class="sidebar">
            <h2>Elements</h2>
            <div class="tools">
                <button id="addParagraph" class="tool-btn" data-type="paragraph">+ Paragraph</button>
                <button id="addHeader" class="tool-btn" data-type="header">+ Header</button>
                <button id="addImage" class="tool-btn" data-type="image">+ Image</button>
            </div>
        </div>

        <!-- Canvas -->
        <div class="preview">
            <h2>Preview</h2>
            <div class="canvas" id="canvas" aria-label="preview-canvas"></div>
            <div style="margin-top:8px;">
                <button id="previewPageBtn" class="preview-btn">Preview Page</button>
            </div>
        </div>

        <!-- Settings & Output -->
        <div class="settings">
            <h2>Post Metadata</h2>

            <div class="settings-group">
                <label>Title</label>
                <input type="text" id="postTitle" placeholder="Post title">
            </div>

            <div class="settings-group">
                <label>Author</label>
                <input type="text" id="postAuthor" placeholder="Author name">
            </div>

            <div class="settings-group">
                <label>Date</label>
                <input type="date" id="postDate">
            </div>

            <div class="settings-group">
              <label>Featured Image</label>
              <div class="featured-image-container">
                <input type="file" id="featuredImageFile" accept="image/*">
                <small>OR (prioritizes uploaded image name)</small>
                <input type="text" id="featuredImage" placeholder="filename.png">
              </div>
            </div>

            <button class="generate-btn" id="generateMarkdownBtn">Generate Markdown</button>

            <div class="markdown-output" id="output" style="display:none;"></div>
            <button class="copy-btn" id="copyBtn" style="display:none;">Copy to Clipboard</button>
        </div>
    </div>

    <!-- Modal (centered) - uses blog-style.css for post styling -->
    <div id="modalOverlay" class="modal-overlay" role="dialog" aria-modal="true">
      <div class="modal" role="document">
        <div class="modal-header">
          <div>
            <strong>Post Preview</strong>
            <div style="font-size:12px;color:#666;">This shows how the post will render.</div>
          </div>
          <div>
            <button id="exportMdFromModal" class="generate-btn" title="Export markdown">Export Markdown</button>
            <button id="modalClose" class="modal-close">Close</button>
          </div>
        </div>

        <div id="modalContent" class="preview-render" tabindex="0">
          <!-- Rendered preview inserted here by JS -->
        </div>
      </div>
    </div>

    <!-- External JS -->
      <script>
      // Set baseUrl for JS to use
      window.siteBaseUrl = "{{ site.baseUrl }}";
    </script>
    <script src="{{ site.baseUrl }}static/js/tool.js"></script>
</body>
</html>